{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "call"
        },
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "budgetMs": {
          "default": 1500,
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "type",
        "schemaVersion",
        "id",
        "model",
        "provider",
        "budgetMs"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "turn"
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "userText": {
          "type": "string"
        },
        "promptTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sttStreaming": {
          "default": false,
          "type": "boolean"
        },
        "ttsStreaming": {
          "default": false,
          "type": "boolean"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "stages": {
          "type": "object",
          "properties": {
            "vad": {
              "type": "object",
              "properties": {
                "startMs": {
                  "type": "number",
                  "minimum": 0
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "startMs",
                "durationMs"
              ],
              "additionalProperties": false
            },
            "stt": {
              "type": "object",
              "properties": {
                "startMs": {
                  "type": "number",
                  "minimum": 0
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "startMs",
                "durationMs"
              ],
              "additionalProperties": false
            },
            "llm": {
              "type": "object",
              "properties": {
                "startMs": {
                  "type": "number",
                  "minimum": 0
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "startMs",
                "durationMs"
              ],
              "additionalProperties": false
            },
            "tts": {
              "type": "object",
              "properties": {
                "startMs": {
                  "type": "number",
                  "minimum": 0
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "startMs",
                "durationMs"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "vad",
            "stt",
            "llm",
            "tts"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "type",
        "index",
        "userText",
        "sttStreaming",
        "ttsStreaming",
        "stages"
      ],
      "additionalProperties": false
    }
  ]
}
